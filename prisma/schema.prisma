// Prisma schema for TomaFix (multi-tenant + roles + onboarding + billing + apartment core)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum TemplateType {
  APARTMENT
  OFFICE
  ESTATE
}

enum MemberRole {
  OWNER_ADMIN
  MANAGER
  TECHNICIAN
  RESIDENT
  STAFF
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceStatus {
  PENDING_OTP
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
}

enum BillingProvider {
  PAYSTACK
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OtpChannel {
  EMAIL
  PHONE
}

enum OtpPurpose {
  OWNER_VERIFY
  INVITE_ACCEPT
  LOGIN
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum ResidentRole {
  TENANT
  MANAGER
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BillingStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum NoticeAudience {
  ALL
  RESIDENTS
  STAFF
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model Workspace {
  id           String          @id @default(cuid())
  name         String
  templateType TemplateType
  status       WorkspaceStatus @default(PENDING_OTP)
  planName     String          @default("Starter")
  billingStatus BillingStatus  @default(ACTIVE)
  nextRenewal  DateTime?
  permissionPolicy Json?

  // Workspace owner (created during onboarding)
  ownerUserId     String?
  ownerVerifiedAt DateTime?
  owner           User? @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  invites       Invite[]
  otps          OtpCode[]
  subscriptions Subscription[]
  payments      Payment[]
  webhookEvents WebhookEvent[]
  auditLogs     AuditLog[]

  // Apartment core
  units     Unit[]
  residents Resident[]
  requests  Request[]
  properties Property[]
  notices   Notice[]
  inspections Inspection[]
  requestMessages RequestMessage[]

  @@index([status])
  @@index([ownerUserId])
  @@index([planName])
  @@index([billingStatus])
}

model User {
  id       String  @id @default(cuid())
  email    String? @unique
  phone    String? @unique
  fullName String?

  // Verification timestamps
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     WorkspaceMember[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  otps            OtpCode[]
  auditLogs       AuditLog[]
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Invite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String?
  phone       String?
  role        MemberRole
  tokenHash   String     @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model OtpCode {
  id String @id @default(cuid())

  // Scope OTPs to a workspace when relevant
  workspaceId String?
  userId      String

  purpose   OtpPurpose
  channel   OtpChannel
  target    String // actual email/phone used
  codeHash  String
  expiresAt DateTime

  consumedAt DateTime?
  createdAt  DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([target])
  @@index([purpose])
  @@index([userId, purpose])
  @@index([workspaceId, purpose])
}

model Subscription {
  id          String           @id @default(cuid())
  workspaceId String
  provider    BillingProvider  @default(PAYSTACK)

  // Paystack subscription identity
  customerCode     String?
  subscriptionCode String?
  emailToken       String?

  planId   String?
  planCode String?

  status           SubscriptionStatus @default(TRIAL)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([workspaceId])
  @@index([planId])
  @@index([status])
}

model Plan {
  id            String       @id @default(cuid())
  name          String
  interval      PlanInterval
  amountPesewas Int
  currency      String       @default("GHS")
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  subscriptions Subscription[]
  payments      Payment[]

  @@index([isActive])
}

model Payment {
  id          String  @id @default(cuid())
  workspaceId String
  planId      String?

  provider  BillingProvider @default(PAYSTACK)
  reference String          @unique

  amountPesewas Int
  currency      String        @default("GHS")
  status        PaymentStatus @default(PENDING)

  // provider metadata
  providerTxnId String?
  channel       String?
  paidAt        DateTime?

  rawEvent  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  // allow multiple payments per workspace
  @@index([workspaceId])
  @@index([planId])
  @@index([status])
}

model WebhookEvent {
  id          String          @id @default(cuid())
  workspaceId String?
  provider    BillingProvider @default(PAYSTACK)

  eventId   String @unique
  eventType String
  reference String?

  receivedAt DateTime @default(now())
  payload    Json

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([reference])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorUserId String?
  action      String
  meta        Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([actorUserId])
}

model Unit {
  id          String     @id @default(cuid())
  workspaceId String
  label       String
  block       String?
  floor       String?
  status      UnitStatus @default(VACANT)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  residents   Resident[]
  requests    Request[]
  inspections Inspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, block, floor])

  // ✅ Prevent duplicate units inside the same workspace by label
  @@unique([workspaceId, label], name: "unit_workspace_label_unique")
}

model Resident {
  id          String         @id @default(cuid())
  workspaceId String
  unitId      String?
  fullName    String
  phone       String?
  email       String?
  role        ResidentRole   @default(TENANT)
  status      ResidentStatus @default(ACTIVE)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  requests  Request[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([unitId])
}

model Request {
  id          String          @id @default(cuid())
  workspaceId String
  unitId      String
  residentId  String?

  title       String
  description String?
  photoUrl    String?
  priority    RequestPriority @default(NORMAL)
  status      RequestStatus   @default(PENDING)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident  Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)
  messages  RequestMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([unitId])
  @@index([residentId])
}

model RequestMessage {
  id           String   @id @default(cuid())
  workspaceId  String
  requestId    String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  request   Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([requestId])
  @@index([createdAt])
}

model Property {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model Notice {
  id          String        @id @default(cuid())
  workspaceId String
  title       String
  body        String
  audience    NoticeAudience @default(ALL)
  seenBy      Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
}

model Inspection {
  id          String           @id @default(cuid())
  workspaceId String
  unitId      String?
  title       String
  dueDate     DateTime
  checklist   Json?
  status      InspectionStatus @default(SCHEDULED)
  result      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([unitId])
  @@index([dueDate])
}
