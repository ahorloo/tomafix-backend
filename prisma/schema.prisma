// Prisma schema for TomaFix (multi-tenant + roles + onboarding + billing + apartment core)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum TemplateType {
  APARTMENT
  OFFICE
  ESTATE
}

enum MemberRole {
  OWNER_ADMIN
  MANAGER
  TECHNICIAN
  RESIDENT
  STAFF
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceStatus {
  PENDING_OTP
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
}

enum BillingProvider {
  PAYSTACK
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OtpChannel {
  EMAIL
  PHONE
}

enum OtpPurpose {
  OWNER_VERIFY
  INVITE_ACCEPT
  LOGIN
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum VisitorStatus {
  EXPECTED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  EXPIRED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ResidentRole {
  TENANT
  OWNER
  MANAGER
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BillingStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum NoticeAudience {
  ALL
  RESIDENTS
  STAFF
}

enum OfficeAreaType {
  FLOOR
  OFFICE
  MEETING_ROOM
  SERVER_ROOM
  RECEPTION
  RESTROOM
  CAFETERIA
  OTHER
}

enum OfficeRequestCategory {
  FACILITY
  IT
  ADMIN
  HR
  PROCUREMENT
  CLEANING
}

enum OfficeCommunityChannelKey {
  GENERAL_HELP
  ADMIN_HELP
  COVERAGE
  UPDATES
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum InspectionScope {
  UNIT
  BLOCK
  FLOOR
}

enum EstateChargeStatus {
  POSTED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

model Template {
  id          String       @id @default(cuid())
  key         TemplateType @unique
  name        String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspaces Workspace[]
  plans      Plan[]
}

model Workspace {
  id               String          @id @default(cuid())
  name             String
  templateType     TemplateType
  templateId       String?
  status           WorkspaceStatus @default(PENDING_OTP)
  planName         String          @default("Starter")
  billingStatus    BillingStatus   @default(ACTIVE)
  nextRenewal      DateTime?
  permissionPolicy Json?

  // Workspace owner (created during onboarding)
  ownerUserId     String?
  ownerVerifiedAt DateTime?
  owner           User?     @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  template        Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // Onboarding reminder (sent once after 24h if workspace not yet active)
  onboardingReminderSentAt DateTime?

  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  invites       Invite[]
  otps          OtpCode[]
  subscriptions Subscription[]
  payments      Payment[]
  webhookEvents WebhookEvent[]
  auditLogs     AuditLog[]

  // Apartment / Estate core
  estates                  Estate[]
  apartmentNotices         ApartmentNotice[]
  apartmentInspections     ApartmentInspection[]
  estateNotices            EstateNotice[]
  estateInspections        EstateInspection[]
  staffBlockAssignments    StaffBlockAssignment[]
  apartmentUnits           ApartmentUnit[]
  apartmentResidents       ApartmentResident[]
  apartmentRequests        ApartmentRequest[]
  estateUnits              EstateUnit[]
  estateResidents          EstateResident[]
  estateRequests           EstateRequest[]
  estateCharges            EstateCharge[]
  estateChargePayments     EstateChargePayment[]
  officeNotices               OfficeNotice[]
  officeInspections           OfficeInspection[]
  officeAssets                OfficeAsset[]
  officeWorkOrders            OfficeWorkOrder[]
  apartmentRequestMessages    ApartmentRequestMessage[]
  estateRequestMessages       EstateRequestMessage[]
  officeAreas                 OfficeArea[]
  officeRequests              OfficeRequest[]
  officeRequestTypes          OfficeRequestType[]
  officeRequestMessages       OfficeRequestMessage[]
  officeWorkOrderMessages     OfficeWorkOrderMessage[]
  officeCommunityChannels     OfficeCommunityChannel[]
  officeCommunityMessages     OfficeCommunityMessage[]

  // Visitor management
  visitors          Visitor[]
  recurringCharges  RecurringCharge[]

  // Integrations
  slackWebhookUrl    String?
  outboundWebhookUrl String?

  @@index([status])
  @@index([ownerUserId])
  @@index([templateId])
  @@index([planName])
  @@index([billingStatus])
}

model User {
  id       String  @id @default(cuid())
  email    String? @unique
  phone    String? @unique
  fullName String?

  // Verification timestamps
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships           WorkspaceMember[]
  ownedWorkspaces       Workspace[]            @relation("WorkspaceOwner")
  otps                  OtpCode[]
  auditLogs             AuditLog[]
  staffBlockAssignments StaffBlockAssignment[]
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, isActive, role])
}

model StaffBlockAssignment {
  id          String   @id @default(cuid())
  workspaceId String
  staffUserId String
  block       String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  staff     User      @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, staffUserId, block])
  @@index([workspaceId, staffUserId])
  @@index([workspaceId, block])
}

model Invite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String?
  phone       String?
  role        MemberRole
  tokenHash   String     @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model OtpCode {
  id String @id @default(cuid())

  // Scope OTPs to a workspace when relevant
  workspaceId String?
  userId      String

  purpose   OtpPurpose
  channel   OtpChannel
  target    String // actual email/phone used
  codeHash  String
  expiresAt DateTime

  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([target])
  @@index([purpose])
  @@index([userId, purpose])
  @@index([workspaceId, purpose])
}

model Subscription {
  id          String          @id @default(cuid())
  workspaceId String
  provider    BillingProvider @default(PAYSTACK)

  // Paystack subscription identity
  customerCode     String?
  subscriptionCode String?
  emailToken       String?

  planId   String?
  planCode String?

  status           SubscriptionStatus @default(TRIAL)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([workspaceId])
  @@index([planId])
  @@index([status])
}

model Plan {
  id            String       @id @default(cuid())
  templateId    String
  name          String
  interval      PlanInterval
  amountPesewas Int
  currency      String       @default("GHS")
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  template      Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  payments      Payment[]

  @@unique([templateId, name, interval])
  @@index([templateId, isActive])
}

model Payment {
  id          String  @id @default(cuid())
  workspaceId String
  planId      String?

  provider  BillingProvider @default(PAYSTACK)
  reference String          @unique

  amountPesewas Int
  currency      String        @default("GHS")
  status        PaymentStatus @default(PENDING)

  // provider metadata
  providerTxnId String?
  channel       String?
  paidAt        DateTime?

  rawEvent  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  // allow multiple payments per workspace
  @@index([workspaceId])
  @@index([planId])
  @@index([status])
}

model WebhookEvent {
  id          String          @id @default(cuid())
  workspaceId String?
  provider    BillingProvider @default(PAYSTACK)

  eventId   String  @unique
  eventType String
  reference String?

  receivedAt DateTime @default(now())
  payload    Json

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([reference])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorUserId String?
  action      String
  meta        Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([actorUserId])
}

model Estate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  code        String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estateUnits       EstateUnit[]
  estateNotices     EstateNotice[]
  estateInspections EstateInspection[]
  charges           EstateCharge[]

  @@unique([workspaceId, name])
  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model ApartmentNotice {
  id          String         @id @default(cuid())
  workspaceId String
  title       String
  body        String
  audience    NoticeAudience @default(ALL)
  seenBy      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
  @@index([workspaceId, audience, createdAt])
}

model EstateNotice {
  id          String         @id @default(cuid())
  workspaceId String
  estateId    String?
  title       String
  body        String
  audience    NoticeAudience @default(ALL)
  seenBy      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?   @relation(fields: [estateId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([estateId])
  @@index([workspaceId, estateId, audience, createdAt])
  @@index([createdAt])
}

model OfficeNotice {
  id          String         @id @default(cuid())
  workspaceId String
  title       String
  body        String
  audience    NoticeAudience @default(ALL)
  seenBy      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
  @@index([workspaceId, audience, createdAt])
}

model ApartmentInspection {
  id          String           @id @default(cuid())
  workspaceId String
  unitId      String?
  scope       InspectionScope  @default(UNIT)
  block       String?
  floor       String?
  title       String
  dueDate     DateTime
  checklist   Json?
  status      InspectionStatus @default(SCHEDULED)
  result      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      ApartmentUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, scope, block, floor])
  @@index([unitId])
  @@index([workspaceId, dueDate])
}

model EstateInspection {
  id          String           @id @default(cuid())
  workspaceId String
  estateId    String?
  unitId      String?
  scope       InspectionScope  @default(UNIT)
  block       String?
  floor       String?
  title       String
  dueDate     DateTime
  checklist   Json?
  status      InspectionStatus @default(SCHEDULED)
  result      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?     @relation(fields: [estateId], references: [id], onDelete: SetNull)
  unit      EstateUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([estateId])
  @@index([workspaceId, estateId, scope, block, floor])
  @@index([unitId])
  @@index([workspaceId, estateId, dueDate])
}

model OfficeInspection {
  id          String           @id @default(cuid())
  workspaceId String
  areaId      String?
  scope       InspectionScope  @default(UNIT)
  block       String?
  floor       String?
  title       String
  dueDate     DateTime
  checklist   Json?
  status      InspectionStatus @default(SCHEDULED)
  result      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  area      OfficeArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([areaId])
  @@index([workspaceId, scope, block, floor])
  @@index([workspaceId, dueDate])
}

// Template-separated physical tables (phase 2)
model ApartmentUnit {
  id          String     @id
  workspaceId String
  label       String
  block       String?
  floor       String?
  status      UnitStatus @default(VACANT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apartmentResidents ApartmentResident[]
  apartmentRequests  ApartmentRequest[]
  apartmentInspections ApartmentInspection[]

  @@unique([workspaceId, label])
  @@index([workspaceId])
  @@index([workspaceId, status])
}

model ApartmentResident {
  id          String         @id
  workspaceId String
  unitId      String?
  fullName    String
  phone       String?
  email       String?
  role        ResidentRole   @default(TENANT)
  status      ResidentStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit              ApartmentUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  apartmentRequests ApartmentRequest[]

  @@index([workspaceId])
  @@index([unitId])
}

model ApartmentRequest {
  id          String          @id
  workspaceId String
  unitId      String
  residentId  String?
  title       String
  description String?
  photoUrl    String?
  priority    RequestPriority @default(NORMAL)
  status      RequestStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      ApartmentUnit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident  ApartmentResident?        @relation(fields: [residentId], references: [id], onDelete: SetNull)
  messages  ApartmentRequestMessage[]

  @@index([workspaceId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
}

model EstateUnit {
  id          String     @id
  workspaceId String
  estateId    String?
  label       String
  block       String?
  floor       String?
  status      UnitStatus @default(VACANT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate          Estate?          @relation(fields: [estateId], references: [id], onDelete: SetNull)
  estateResidents EstateResident[]
  estateRequests  EstateRequest[]
  charges         EstateCharge[]
  estateInspections EstateInspection[]

  @@unique([workspaceId, estateId, label])
  @@index([workspaceId])
  @@index([estateId])
}

model EstateResident {
  id          String         @id
  workspaceId String
  unitId      String?
  fullName    String
  phone       String?
  email       String?
  role        ResidentRole   @default(TENANT)
  status      ResidentStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit           EstateUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  estateRequests EstateRequest[]
  charges        EstateCharge[]

  @@index([workspaceId])
  @@index([unitId])
}

model EstateRequest {
  id          String          @id
  workspaceId String
  unitId      String
  residentId  String?
  title       String
  description String?
  photoUrl    String?
  category    String?
  assignedToUserId String?
  assignedToName   String?
  vendorName       String?
  dueAt            DateTime?
  resolvedAt       DateTime?
  estimatedCost    Float?
  priority    RequestPriority @default(NORMAL)
  status      RequestStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      EstateUnit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident  EstateResident?        @relation(fields: [residentId], references: [id], onDelete: SetNull)
  messages  EstateRequestMessage[]

  @@index([workspaceId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
  @@index([workspaceId, category])
  @@index([workspaceId, assignedToUserId])
  @@index([workspaceId, dueAt])
}

model EstateCharge {
  id               String            @id @default(cuid())
  workspaceId      String
  estateId         String?
  unitId           String?
  residentId       String?
  title            String
  category         String?
  notes            String?
  amount           Float
  currency         String            @default("GHS")
  dueDate          DateTime
  status           EstateChargeStatus @default(POSTED)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate           Estate?           @relation(fields: [estateId], references: [id], onDelete: SetNull)
  unit             EstateUnit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident         EstateResident?   @relation(fields: [residentId], references: [id], onDelete: SetNull)
  payments         EstateChargePayment[]

  @@index([workspaceId])
  @@index([estateId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, category])
}

model EstateChargePayment {
  id          String      @id @default(cuid())
  workspaceId String
  chargeId    String
  amount      Float
  currency    String      @default("GHS")
  paidAt      DateTime    @default(now())
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  charge    EstateCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([chargeId])
  @@index([workspaceId, paidAt])
}

model ApartmentRequestMessage {
  id           String   @id
  workspaceId  String
  requestId    String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  request   ApartmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([requestId])
  @@index([workspaceId, requestId, createdAt])
  @@index([createdAt])
}

model EstateRequestMessage {
  id           String   @id
  workspaceId  String
  requestId    String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  request   EstateRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([requestId])
  @@index([workspaceId, requestId, createdAt])
  @@index([createdAt])
}

model OfficeArea {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  type        OfficeAreaType @default(OTHER)
  floor       String?
  description String?
  ownerUserId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  officeRequests   OfficeRequest[]
  officeWorkOrders OfficeWorkOrder[]
  officeInspections OfficeInspection[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([ownerUserId])
  @@index([workspaceId, type])
}

model OfficeRequest {
  id              String                @id @default(cuid())
  workspaceId     String
  areaId          String
  requestTypeId   String?
  submitterUserId String?
  submitterName   String
  category        OfficeRequestCategory @default(FACILITY)
  title           String
  description     String?
  photoUrl        String?
  priority        RequestPriority       @default(NORMAL)
  status          RequestStatus         @default(PENDING)
  workOrderId     String?
  slaDeadline     DateTime?
  resolvedAt      DateTime?
  isEscalated     Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  area         OfficeArea         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  requestType  OfficeRequestType? @relation(fields: [requestTypeId], references: [id], onDelete: SetNull)
  messages     OfficeRequestMessage[]

  @@index([workspaceId])
  @@index([areaId])
  @@index([requestTypeId])
  @@index([workspaceId, status])
  @@index([workspaceId, category])
  @@index([workspaceId, status, createdAt])
}

model OfficeRequestType {
  id            String                @id @default(cuid())
  workspaceId   String
  label         String
  baseCategory  OfficeRequestCategory @default(FACILITY)
  isActive      Boolean               @default(true)
  slaHours      Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requests  OfficeRequest[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model OfficeRequestMessage {
  id           String   @id @default(cuid())
  workspaceId  String
  requestId    String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  request   OfficeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([requestId])
  @@index([workspaceId, requestId, createdAt])
}

model OfficeAsset {
  id               String    @id @default(cuid())
  workspaceId      String
  name             String
  category         String?
  serialNo         String?
  location         String?
  status           String    @default("ACTIVE")
  lastServicedAt   DateTime?
  nextServiceAt    DateTime?
  notes            String?
  // Preventive maintenance scheduling
  pmIntervalDays   Int?      // null = no recurring PM
  pmAutoCreate     Boolean   @default(false)
  // Cost tracking
  costPerService   Float?
  totalCostLogged  Float?    @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  officeWorkOrders OfficeWorkOrder[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, pmAutoCreate])
}

model OfficeWorkOrder {
  id               String                @id @default(cuid())
  workspaceId      String
  areaId           String?
  assetId          String?
  assignedToUserId String?
  category         OfficeRequestCategory @default(FACILITY)
  title            String
  description      String?
  status           String                @default("OPEN")
  priority         RequestPriority       @default(NORMAL)
  slaDeadline      DateTime?
  completionNote   String?
  proofPhotoUrl    String?
  closedAt         DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  area      OfficeArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)
  asset     OfficeAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  messages  OfficeWorkOrderMessage[]

  @@index([workspaceId])
  @@index([areaId])
  @@index([assetId])
  @@index([workspaceId, status])
  @@index([workspaceId, assignedToUserId])
}

model OfficeWorkOrderMessage {
  id           String   @id @default(cuid())
  workspaceId  String
  workOrderId  String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workOrder  OfficeWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workOrderId])
  @@index([workspaceId, workOrderId, createdAt])
}

model OfficeCommunityChannel {
  id          String                    @id @default(cuid())
  workspaceId String
  key         OfficeCommunityChannelKey
  name        String
  description String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  workspace Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  OfficeCommunityMessage[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([workspaceId, key])
}

model OfficeCommunityMessage {
  id           String   @id @default(cuid())
  workspaceId  String
  channelId    String
  senderUserId String?
  senderName   String
  body         String
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   OfficeCommunityChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([channelId])
  @@index([workspaceId, channelId, createdAt])
}

// ── Technician Marketplace ─────────────────────────────────────────────────────

enum TechnicianApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model TechnicianApplication {
  id             String                        @id @default(cuid())
  businessName   String
  contactPerson  String
  phone          String
  whatsapp       String
  email          String
  businessAddress String
  businessLocationUrl String?
  serviceAreas   String
  serviceAreaLinks String[] @default([])
  serviceAreaLocations Json?
  categories     String[]
  yearsInOperation String?
  teamSize       String?
  bio            String?
  website        String?
  logoUrl        String?
  latitude       Float
  longitude      Float
  status         TechnicianApplicationStatus   @default(PENDING)
  reviewNote     String?
  adminNotes     String?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Admin Panel ────────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  BILLING_ADMIN
  REVIEW_ADMIN
  CONTENT_ADMIN
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         AdminRole @default(OPS_ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions  AdminSession[]
  auditLogs AdminAuditLog[]

  @@index([email])
  @@index([role])
}

model AdminSession {
  id          String   @id @default(cuid())
  adminUserId String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  twoFactorVerified Boolean   @default(false)
  otpHash           String?
  otpExpiresAt      DateTime?

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminUserId])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  adminEmail  String
  action      String
  targetType  String
  targetId    String?
  meta        Json?
  createdAt   DateTime @default(now())

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
}

// ── Visitor Management ─────────────────────────────────────────────────────────

model Visitor {
  id          String        @id @default(cuid())
  workspaceId String

  // Who invited them
  invitedByUserId String?
  invitedByName   String?

  // Which unit/area they are visiting (apartment/estate or office)
  unitId   String?
  unitLabel String?
  areaId   String?
  areaName String?

  // Visitor details
  name    String
  phone   String?
  email   String?
  purpose String?

  // Unique token used to generate/validate QR code
  qrToken String @unique @default(cuid())

  status    VisitorStatus @default(EXPECTED)
  validFrom DateTime?
  validUntil DateTime?

  checkedInAt  DateTime?
  checkedOutAt DateTime?
  checkedInByName  String?
  checkedOutByName String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([qrToken])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

// ── Recurring Billing ──────────────────────────────────────────────────────────

model RecurringCharge {
  id          String             @id @default(cuid())
  workspaceId String
  estateId    String?

  title       String
  category    String?
  amount      Float
  currency    String             @default("GHS")
  frequency   RecurringFrequency @default(MONTHLY)
  dayOfMonth  Int?               // e.g. 1 = 1st of every month
  notes       String?

  isActive    Boolean            @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([nextRunAt])
}
