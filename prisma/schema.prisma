// Prisma schema for TomaFix (multi-tenant + roles + onboarding + billing + apartment core)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum TemplateType {
  APARTMENT
  OFFICE
  ESTATE
}

enum MemberRole {
  OWNER_ADMIN
  MANAGER
  TECHNICIAN
  RESIDENT
  STAFF
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceStatus {
  PENDING_OTP
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
}

enum BillingProvider {
  PAYSTACK
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OtpChannel {
  EMAIL
  PHONE
}

enum OtpPurpose {
  OWNER_VERIFY
  INVITE_ACCEPT
  LOGIN
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum ResidentRole {
  TENANT
  MANAGER
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BillingStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum NoticeAudience {
  ALL
  RESIDENTS
  STAFF
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum InspectionScope {
  UNIT
  BLOCK
  FLOOR
}

model Template {
  id          String       @id @default(cuid())
  key         TemplateType @unique
  name        String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspaces Workspace[]
  plans      Plan[]
}

model Workspace {
  id               String          @id @default(cuid())
  name             String
  templateType     TemplateType
  templateId       String?
  status           WorkspaceStatus @default(PENDING_OTP)
  planName         String          @default("Starter")
  billingStatus    BillingStatus   @default(ACTIVE)
  nextRenewal      DateTime?
  permissionPolicy Json?

  // Workspace owner (created during onboarding)
  ownerUserId     String?
  ownerVerifiedAt DateTime?
  owner           User?     @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  template        Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  invites       Invite[]
  otps          OtpCode[]
  subscriptions Subscription[]
  payments      Payment[]
  webhookEvents WebhookEvent[]
  auditLogs     AuditLog[]

  // Apartment / Estate core
  estates                  Estate[]
  properties               Property[]
  notices                  Notice[]
  inspections              Inspection[]
  staffBlockAssignments    StaffBlockAssignment[]
  apartmentUnits           ApartmentUnit[]
  apartmentResidents       ApartmentResident[]
  apartmentRequests        ApartmentRequest[]
  estateUnits              EstateUnit[]
  estateResidents          EstateResident[]
  estateRequests           EstateRequest[]
  officeAssets             OfficeAsset[]
  officeWorkOrders         OfficeWorkOrder[]
  apartmentRequestMessages ApartmentRequestMessage[]
  estateRequestMessages    EstateRequestMessage[]

  @@index([status])
  @@index([ownerUserId])
  @@index([templateId])
  @@index([planName])
  @@index([billingStatus])
}

model User {
  id       String  @id @default(cuid())
  email    String? @unique
  phone    String? @unique
  fullName String?

  // Verification timestamps
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships           WorkspaceMember[]
  ownedWorkspaces       Workspace[]            @relation("WorkspaceOwner")
  otps                  OtpCode[]
  auditLogs             AuditLog[]
  staffBlockAssignments StaffBlockAssignment[]
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, isActive, role])
}

model StaffBlockAssignment {
  id          String   @id @default(cuid())
  workspaceId String
  staffUserId String
  block       String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  staff     User      @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, staffUserId, block])
  @@index([workspaceId, staffUserId])
  @@index([workspaceId, block])
}

model Invite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String?
  phone       String?
  role        MemberRole
  tokenHash   String     @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model OtpCode {
  id String @id @default(cuid())

  // Scope OTPs to a workspace when relevant
  workspaceId String?
  userId      String

  purpose   OtpPurpose
  channel   OtpChannel
  target    String // actual email/phone used
  codeHash  String
  expiresAt DateTime

  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([target])
  @@index([purpose])
  @@index([userId, purpose])
  @@index([workspaceId, purpose])
}

model Subscription {
  id          String          @id @default(cuid())
  workspaceId String
  provider    BillingProvider @default(PAYSTACK)

  // Paystack subscription identity
  customerCode     String?
  subscriptionCode String?
  emailToken       String?

  planId   String?
  planCode String?

  status           SubscriptionStatus @default(TRIAL)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([workspaceId])
  @@index([planId])
  @@index([status])
}

model Plan {
  id            String       @id @default(cuid())
  templateId    String
  name          String
  interval      PlanInterval
  amountPesewas Int
  currency      String       @default("GHS")
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  template      Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  payments      Payment[]

  @@unique([templateId, name, interval])
  @@index([templateId, isActive])
}

model Payment {
  id          String  @id @default(cuid())
  workspaceId String
  planId      String?

  provider  BillingProvider @default(PAYSTACK)
  reference String          @unique

  amountPesewas Int
  currency      String        @default("GHS")
  status        PaymentStatus @default(PENDING)

  // provider metadata
  providerTxnId String?
  channel       String?
  paidAt        DateTime?

  rawEvent  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  // allow multiple payments per workspace
  @@index([workspaceId])
  @@index([planId])
  @@index([status])
}

model WebhookEvent {
  id          String          @id @default(cuid())
  workspaceId String?
  provider    BillingProvider @default(PAYSTACK)

  eventId   String  @unique
  eventType String
  reference String?

  receivedAt DateTime @default(now())
  payload    Json

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([reference])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorUserId String?
  action      String
  meta        Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([actorUserId])
}

model Estate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  code        String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estateUnits EstateUnit[]

  @@unique([workspaceId, name])
  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model Property {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Notice {
  id          String         @id @default(cuid())
  workspaceId String
  title       String
  body        String
  audience    NoticeAudience @default(ALL)
  seenBy      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, audience, createdAt])
  @@index([createdAt])
}

model Inspection {
  id          String           @id @default(cuid())
  workspaceId String
  unitId      String?
  scope       InspectionScope  @default(UNIT)
  block       String?
  floor       String?
  title       String
  dueDate     DateTime
  checklist   Json?
  status      InspectionStatus @default(SCHEDULED)
  result      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, scope, block, floor])
  @@index([unitId])
  @@index([dueDate])
}

// Template-separated physical tables (phase 2)
model ApartmentUnit {
  id          String     @id
  workspaceId String
  label       String
  block       String?
  floor       String?
  status      UnitStatus @default(VACANT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apartmentResidents ApartmentResident[]
  apartmentRequests  ApartmentRequest[]

  @@unique([workspaceId, label])
  @@index([workspaceId])
  @@index([workspaceId, status])
}

model ApartmentResident {
  id          String         @id
  workspaceId String
  unitId      String?
  fullName    String
  phone       String?
  email       String?
  role        ResidentRole   @default(TENANT)
  status      ResidentStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit              ApartmentUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  apartmentRequests ApartmentRequest[]

  @@index([workspaceId])
  @@index([unitId])
}

model ApartmentRequest {
  id          String          @id
  workspaceId String
  unitId      String
  residentId  String?
  title       String
  description String?
  photoUrl    String?
  priority    RequestPriority @default(NORMAL)
  status      RequestStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      ApartmentUnit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident  ApartmentResident?        @relation(fields: [residentId], references: [id], onDelete: SetNull)
  messages  ApartmentRequestMessage[]

  @@index([workspaceId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
}

model EstateUnit {
  id          String     @id
  workspaceId String
  estateId    String?
  label       String
  block       String?
  floor       String?
  status      UnitStatus @default(VACANT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate          Estate?          @relation(fields: [estateId], references: [id], onDelete: SetNull)
  estateResidents EstateResident[]
  estateRequests  EstateRequest[]

  @@unique([workspaceId, estateId, label])
  @@index([workspaceId])
  @@index([estateId])
}

model EstateResident {
  id          String         @id
  workspaceId String
  unitId      String?
  fullName    String
  phone       String?
  email       String?
  role        ResidentRole   @default(TENANT)
  status      ResidentStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit           EstateUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  estateRequests EstateRequest[]

  @@index([workspaceId])
  @@index([unitId])
}

model EstateRequest {
  id          String          @id
  workspaceId String
  unitId      String
  residentId  String?
  title       String
  description String?
  photoUrl    String?
  priority    RequestPriority @default(NORMAL)
  status      RequestStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  unit      EstateUnit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident  EstateResident?        @relation(fields: [residentId], references: [id], onDelete: SetNull)
  messages  EstateRequestMessage[]

  @@index([workspaceId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
}

model ApartmentRequestMessage {
  id           String   @id
  workspaceId  String
  requestId    String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  request   ApartmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([requestId])
  @@index([workspaceId, requestId, createdAt])
  @@index([createdAt])
}

model EstateRequestMessage {
  id           String   @id
  workspaceId  String
  requestId    String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  request   EstateRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([requestId])
  @@index([workspaceId, requestId, createdAt])
  @@index([createdAt])
}

model OfficeAsset {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  category    String?
  serialNo    String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  officeWorkOrders OfficeWorkOrder[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model OfficeWorkOrder {
  id          String   @id @default(cuid())
  workspaceId String
  assetId     String?
  title       String
  description String?
  status      String   @default("OPEN")
  priority    String   @default("NORMAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  asset     OfficeAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assetId])
  @@index([workspaceId, status])
}
