  area      OfficeArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)
  asset     OfficeAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  messages  OfficeWorkOrderMessage[]

  @@index([workspaceId])
  @@index([areaId])
  @@index([assetId])
  @@index([workspaceId, status])
  @@index([workspaceId, assignedToUserId])
}

model OfficeWorkOrderMessage {
  id           String   @id @default(cuid())
  workspaceId  String
  workOrderId  String
  senderUserId String?
  senderName   String
  body         String
  createdAt    DateTime @default(now())

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workOrder  OfficeWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workOrderId])
  @@index([workspaceId, workOrderId, createdAt])
}

model OfficeCommunityChannel {
  id          String                    @id @default(cuid())
  workspaceId String
  key         OfficeCommunityChannelKey
  name        String
  description String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  workspace Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  OfficeCommunityMessage[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([workspaceId, key])
}

model OfficeCommunityMessage {
  id           String   @id @default(cuid())
  workspaceId  String
  channelId    String
  senderUserId String?
  senderName   String
  body         String
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   OfficeCommunityChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([channelId])
  @@index([workspaceId, channelId, createdAt])
}

// ── Technician Marketplace ─────────────────────────────────────────────────────

enum TechnicianApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model TechnicianApplication {
  id             String                        @id @default(cuid())
  businessName   String
  contactPerson  String
  phone          String
  whatsapp       String
  email          String
  businessAddress String
  businessLocationUrl String?
  serviceAreas   String
  serviceAreaLinks String[] @default([])
  serviceAreaLocations Json?
  categories     String[]
  yearsInOperation String?
  teamSize       String?
  bio            String?
  website        String?
  logoUrl        String?
  latitude       Float
  longitude      Float
  status         TechnicianApplicationStatus   @default(PENDING)
  reviewNote     String?
  adminNotes     String?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Admin Panel ────────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  BILLING_ADMIN
  REVIEW_ADMIN
  CONTENT_ADMIN
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         AdminRole @default(OPS_ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions  AdminSession[]
  resetTokens AdminPasswordResetToken[]
  auditLogs AdminAuditLog[]

  @@index([email])
  @@index([role])
}

model AdminSession {
  id          String   @id @default(cuid())
  adminUserId String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  twoFactorVerified Boolean   @default(false)
  otpHash           String?
  otpExpiresAt      DateTime?

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminUserId])
}

model AdminPasswordResetToken {
  id          String   @id @default(cuid())
  adminUserId String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  adminEmail  String
  action      String
  targetType  String
  targetId    String?
  meta        Json?
  createdAt   DateTime @default(now())

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
}

// ── Visitor Management ─────────────────────────────────────────────────────────

model EstateLease {
  id                String      @id @default(cuid())
  workspaceId       String
  estateId          String?
  unitId            String
  residentId        String?
  leaseHolderName   String
  startDate         DateTime
  endDate           DateTime
  monthlyRent       Float?
  securityDeposit   Float?
  renewalNoticeDays Int         @default(30)
  status            LeaseStatus @default(DRAFT)
  agreementUrl      String?
  notes             String?
  moveInDate        DateTime?
  moveOutDate       DateTime?
  expiryReminderSentAt DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?         @relation(fields: [estateId], references: [id], onDelete: SetNull)
  unit      EstateUnit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident  EstateResident? @relation(fields: [residentId], references: [id], onDelete: SetNull)
  reminderLogs EstateReminderLog[]

  @@index([workspaceId])
  @@index([estateId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
  @@index([workspaceId, endDate])
}

model EstateUtilityMeter {
  id             String             @id @default(cuid())
  workspaceId    String
  estateId       String?
  unitId         String
  type           UtilityType
  label          String
  meterNumber    String?
  status         UtilityMeterStatus @default(ACTIVE)
  unitRate       Float?
  fixedCharge    Float?
  lastReadingValue Float?
  lastReadingAt  DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?               @relation(fields: [estateId], references: [id], onDelete: SetNull)
  unit      EstateUnit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  readings  EstateUtilityReading[]

  @@index([workspaceId])
  @@index([estateId])
  @@index([unitId])
  @@index([workspaceId, type])
  @@index([workspaceId, status])
}

model EstateUtilityReading {
  id            String      @id @default(cuid())
  workspaceId   String
  meterId       String
  chargeId      String?
  readingDate   DateTime
  readingValue  Float
  previousValue Float?
  consumption   Float?
  unitRate      Float?
  fixedCharge   Float?
  billedAmount  Float?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meter     EstateUtilityMeter @relation(fields: [meterId], references: [id], onDelete: Cascade)
  charge    EstateCharge?      @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([meterId])
  @@index([chargeId])
  @@index([workspaceId, readingDate])
}

model EstateViolation {
  id             String          @id @default(cuid())
  workspaceId    String
  estateId       String?
  unitId         String?
  residentId     String?
  category       String?
  title          String
  description    String?
  severity       String?
  status         ViolationStatus @default(OPEN)
  dueDate        DateTime?
  resolvedAt     DateTime?
  fineAmount     Float?
  evidencePhotos Json?
  resolutionNote String?
  createdByName  String?
  closedByName   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?         @relation(fields: [estateId], references: [id], onDelete: SetNull)
  unit      EstateUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident  EstateResident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([estateId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
}

model EstateApprovalRequest {
  id               String         @id @default(cuid())
  workspaceId      String
  estateId         String?
  unitId           String?
  residentId       String?
  type             String
  title            String
  description      String?
  attachmentUrls   Json?
  requestedStartAt DateTime?
  requestedEndAt   DateTime?
  status           ApprovalStatus @default(PENDING)
  submittedAt      DateTime       @default(now())
  reviewedAt       DateTime?
  reviewedByName   String?
  decisionNote     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?         @relation(fields: [estateId], references: [id], onDelete: SetNull)
  unit      EstateUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident  EstateResident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([estateId])
  @@index([unitId])
  @@index([residentId])
  @@index([workspaceId, status])
}

model EstateInspectionTemplate {
  id          String                 @id @default(cuid())
  workspaceId String
  estateId    String?
  name        String
  kind        InspectionTemplateKind @default(CUSTOM)
  description String?
  checklist   Json
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate       Estate?           @relation(fields: [estateId], references: [id], onDelete: SetNull)
  inspections  EstateInspection[]

  @@index([workspaceId])
  @@index([estateId])
  @@index([workspaceId, isActive])
}

model EstateEmergencyAlert {
  id          String               @id @default(cuid())
  workspaceId String
  estateId    String?
  title       String
  body        String
  audience    NoticeAudience       @default(ALL)
  channels    Json?
  status      EmergencyAlertStatus @default(DRAFT)
  sentAt      DateTime?
  sentByName  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  estate    Estate?   @relation(fields: [estateId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([estateId])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

model EstateReminderLog {
  id             String       @id @default(cuid())
  workspaceId     String
  chargeId        String?
  leaseId         String?
  type            ReminderType
  recipientEmail  String
  recipientPhone  String?
  sentAt          DateTime    @default(now())

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  charge    EstateCharge? @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  lease     EstateLease?  @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([chargeId])
  @@index([leaseId])
  @@index([workspaceId, type, sentAt])
}
