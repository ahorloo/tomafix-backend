PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tomafix
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tomafix_shadow

FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
# Production/stable origins. In development, localhost/127/private-network dev origins are also allowed automatically.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
BILLING_ADMIN_KEY=replace-with-a-long-random-admin-key

PAYSTACK_MODE=test
PAYSTACK_SECRET_KEY=replace-with-your-paystack-secret
PAYSTACK_PUBLIC_KEY=replace-with-your-paystack-public-key
PAYSTACK_CALLBACK_URL=http://localhost:5173/onboarding/payment-success
PAYSTACK_CURRENCY_OVERRIDE=GHS
PAYSTACK_OMIT_CURRENCY=false
ALLOW_LIVE_PAYSTACK_IN_DEV=false

RESEND_API_KEY=replace-with-your-resend-key
RESEND_FROM=TomaFix <onboarding@example.com>
EMAIL_FROM=TomaFix <onboarding@example.com>
EMAIL_LOGO_URL=https://www.tomafix.com/bimi-logo-preview.jpg

# SMS
# provider: none | mock | hubtel
NOTIFICATION_SMS_ENABLED=false
SMS_PROVIDER=mock
HUBTEL_SMS_CLIENT_ID=
HUBTEL_SMS_CLIENT_SECRET=
HUBTEL_SMS_SENDER_ID=TomaFix
HUBTEL_SMS_BASE_URL=https://smsc.hubtel.com/v1/messages/send
HUBTEL_SMS_DELIVERY_REPORT=true

LOCAL_BYPASS_PAYMENT=false
LOCAL_RELAX_GUARDS=false
BILLING_DUNNING_INTERVAL_MIN=0
